      "format": "musicxml",
      "corpus_status": "synthetic_fixture",
      "description": "Two parts at C4 unison.",
      "expected_profile": "profile_sensitive_pairwise",
      "include_in_regression": true,
      "limitations": "Tests occupied_space vs component_weighted contrast."
    },
    {
      "benchmark_id": "register_shift",
